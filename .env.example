# Kevin runs fully offline by default with a deterministic MockLLM - no key needed.
#
# To wire a real OpenAI-compatible language layer (DeepSeek / GPT-4o, matching the
# rest of the ecosystem), set the flag and a key, then implement the client seam in
# kevin/llm_client.py:get_default_client(). The engines never change.
KEVIN_USE_REAL_LLM=0
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
