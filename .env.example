# Kevin runs fully offline by default with a deterministic MockLLM - no key needed.
#
# To use a real OpenAI-compatible language layer, install the extra and set a key:
#   pip install -e ".[llm]"
# DEEPSEEK_API_KEY takes priority (model deepseek-chat); else OPENAI_API_KEY (gpt-4o).
# The engines never change - only the language layer moves.
KEVIN_USE_REAL_LLM=0
# DEEPSEEK_API_KEY=sk-...      # DEEPSEEK_API_KEY2 is also accepted
# OPENAI_API_KEY=sk-...

# Predict where the solution spaces are with DESi's real blind-spot coverage.
# Install DESi (pip install -e ".[desi]" or -e ../DESi); falls back if absent.
# KEVIN_USE_DESI=1
# DESI_ROOT=/path/to/DESi
# Transient-failure retry for the real client (proxied-egress DNS flakiness etc.)
# KEVIN_LLM_RETRIES=4
# KEVIN_LLM_BACKOFF=0.5

# Web server (kevin-serve)
# KEVIN_HOST=127.0.0.1
# KEVIN_PORT=8000

# Layer-9 ledger: where methods learned from "this worked" are persisted (JSONL).
# Default: ~/.kevin/layer9.jsonl
# KEVIN_LAYER9=/path/to/layer9.jsonl
